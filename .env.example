# ── App ───────────────────────────────────────────────
APP_ENV=local
LOG_LEVEL=INFO
# local_full | remote_llm | demo_stub  (v1 default: local_full)
DEPLOYMENT_MODE=local_full

# ── Database ──────────────────────────────────────────
DB__SQLITE_PATH=./data/bharatai.db
DB__BUSY_TIMEOUT_MS=5000

# ── LLM (Ollama) ──────────────────────────────────────
LLM__BASE_URL=http://localhost:11434
LLM__DEFAULT_MODEL=gemma3:12b
LLM__FAST_MODEL=qwen2.5:7b
LLM__HEAVY_MODEL=qwen2.5:14b
LLM__TIMEOUT_S=120
LLM__TEMPERATURE=0.0

# ── Embeddings ────────────────────────────────────────
EMBEDDING__MODEL_NAME=BAAI/bge-small-en-v1.5
EMBEDDING__DEVICE=cpu

# ── Knowledge base (RAG) ──────────────────────────────
KNOWLEDGE__INDEX_DIR=./data/index/faiss
KNOWLEDGE__CHUNK_SIZE=512
KNOWLEDGE__CHUNK_OVERLAP=64
KNOWLEDGE__TOP_K=20
KNOWLEDGE__MIN_SCORE=0.35

# ── Security (auth / tokens) ──────────────────────────
# MUST be a long random secret outside local dev (e.g. `openssl rand -hex 32`).
SECURITY__TOKEN_SECRET=dev-insecure-change-me
SECURITY__TOKEN_TTL_SECONDS=3600
SECURITY__PBKDF2_ITERATIONS=600000
SECURITY__OTP_TTL_SECONDS=300

# ── OCR (PaddleOCR) ───────────────────────────────────
OCR__LANG=en
OCR__USE_GPU=false
OCR__UPLOAD_DIR=./data/uploads
OCR__MAX_FILE_MB=10
